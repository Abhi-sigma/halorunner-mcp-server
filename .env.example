# ---------------------------------------------------------------
# gp-mcp-server environment
# Copy to .env.local for dev. In AWS, these come from Secrets Manager.
# ---------------------------------------------------------------

# Upstream .NET API
#   local dev:   https://localhost:53714
#   staging:     https://api.staging.ygpapp.com
#   production:  https://api.ygpapp.com/web
API_BASE_URL=https://localhost:53714

# Optional API key header forwarded to the .NET API.
# Matches VITE_API_KEY used by the web frontends. Leave blank if unused.
API_KEY=

# Cognito Web pool (staff users)
COGNITO_REGION=ap-southeast-2
COGNITO_USER_POOL_ID=ap-southeast-2_7AEltCLXS
COGNITO_CLIENT_ID=7c3delbo3qpf0n5ek1bu37itmc
COGNITO_HOSTED_UI_DOMAIN=https://ap-southeast-27aeltclxs.auth.ap-southeast-2.amazoncognito.com
COGNITO_SCOPES=openid email phone profile

# MCP server's public URL — used for its OAuth metadata AND as the
# redirect_uri that Cognito will redirect back to during sign-in.
# IMPORTANT: `{PUBLIC_BASE_URL}/oauth/callback` must be in the Cognito
# Web app client's CallbackURLs list.
#   Local:   http://localhost:3000           → add http://localhost:3000/oauth/callback
#   Prod:    https://mcp.api.ygpapp.com      → add https://mcp.api.ygpapp.com/oauth/callback
PUBLIC_BASE_URL=http://localhost:3000

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# CORS — comma-separated origins allowed to hit /mcp.
# Use "*" for local dev. In staging/production the server will refuse to boot
# unless this is set to explicit https:// origins.
# Example prod: CORS_ALLOWED_ORIGINS=https://claude.ai,https://app.claude.ai
CORS_ALLOWED_ORIGINS=*

# ---------------------------------------------------------------
# OAuth store driver
#   memory — in-process Map; single node, not durable (dev default).
#   dynamo — DynamoDB; required for multi-instance or prod/staging.
# ---------------------------------------------------------------
STORE_DRIVER=memory
# Required when STORE_DRIVER=dynamo:
# DDB_CLIENTS_TABLE=mcp_clients
# DDB_PENDING_TABLE=mcp_pending_auths
# DDB_CODES_TABLE=mcp_codes

# ---------------------------------------------------------------
# Secrets Manager (optional)
# If set, the JSON secret at this ID is pulled at boot and merged into
# process.env. Keys already present in the environment are not overwritten.
# Use in prod/staging to keep COGNITO_* / API_KEY out of task definitions.
# ---------------------------------------------------------------
# SECRETS_MANAGER_SECRET_ID=arn:aws:secretsmanager:ap-southeast-2:...:secret:gp-mcp/prod-abc

# Dev only — allow self-signed upstream cert (localhost:53714).
# DO NOT set in production.
NODE_TLS_REJECT_UNAUTHORIZED=0
