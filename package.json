{
  "name": "gp-mcp-server",
  "version": "0.1.0",
  "description": "MCP server that proxies HaloRunner .NET API endpoints with PII redaction and Cognito OAuth.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && npm run copy-config",
    "copy-config": "node -e \"require('fs').mkdirSync('dist/config',{recursive:true});require('fs').copyFileSync('src/config/tools.json','dist/config/tools.json')\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "generate:tools": "tsx scripts/generate-tools-from-swagger.ts",
    "e2e": "tsx scripts/e2e-api-test.ts",
    "simulate": "tsx scripts/simulate.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/client-secrets-manager": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
